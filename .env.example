# Neon Postgres — copy to `.env` and fill in.
# Pooled connection (…-pooler.…neon.tech) used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Direct connection (no -pooler) used by Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# Google Cloud service account for live Cloud Run discovery.
# Path to the service account JSON key file.
GOOGLE_APPLICATION_CREDENTIALS=""
# GCP project to scan.
GCP_PROJECT_ID=""
